{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "description": "__MSG_ext_description__",
  "version": "1.1.0",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage", "commands"],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_action_title__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "zoom_in_fine": {
      "suggested_key": {
        "default": "Ctrl+Shift+Up",
        "mac": "MacCtrl+Shift+Up"
      },
      "description": "__MSG_command_zoom_in__"
    },
    "zoom_out_fine": {
      "suggested_key": {
        "default": "Ctrl+Shift+Down",
        "mac": "MacCtrl+Shift+Down"
      },
      "description": "__MSG_command_zoom_out__"
    }
  }
}
